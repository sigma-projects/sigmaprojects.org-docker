<style>
  .contact-hero { text-align: center; padding: 3rem 1rem 2.5rem; }
  .contact-hero h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; color: #111; margin-bottom: .75rem; }
  .contact-hero p { font-size: 1.4rem; color: #555; max-width: 580px; margin: 0 auto; line-height: 1.7; }

  .contact-cards { display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center; margin: 2.5rem 0; }
  .contact-card { flex: 1 1 220px; max-width: 300px; background: #f8f8f8; border: 1px solid #e8e8e8; border-radius: 12px; padding: 1.75rem 1.5rem; text-align: center; }
  .contact-card .cc-icon { font-size: 2.5rem; color: #888; margin-bottom: 1rem; }
  .contact-card h5 { font-size: 1.25rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; color: #444; margin: 0 0 .6rem; }
  .contact-card p, .contact-card address { font-size: 1.2rem; color: #666; line-height: 1.7; margin: 0; font-style: normal; }
  .contact-card a { color: #333; text-decoration: underline; }
  .contact-card a:hover { color: #000; }

  .contact-social { text-align: center; margin: 2rem 0 1rem; }
